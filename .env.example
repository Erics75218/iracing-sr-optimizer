# iRacing OAuth2 (required for Data API – endpoints return 401 without auth).
IRACING_CLIENT_ID=
IRACING_CLIENT_SECRET=

# Optional: redirect URI. Must match EXACTLY what iRacing approved for your client.
# - Local dev (if iRacing approved 127.0.0.1): use the line below and open app at http://127.0.0.1:3000
# IRACING_REDIRECT_URI=http://127.0.0.1:3000/api/auth/iracing/callback
# - Production: do NOT set this on Vercel so the app uses https://iracing-sr-optimizer.vercel.app/api/auth/iracing/callback
#   (iRacing must have that exact URI approved for production to work)
