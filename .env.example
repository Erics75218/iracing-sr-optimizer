# iRacing OAuth2 (required for Data API – endpoints return 401 without auth).
# Register at https://oauth.iracing.com/oauth2/book/client_registration.html
# with audience "data-server". Add BOTH redirect URIs so one client works locally and in production:
#   - http://localhost:3000/api/auth/iracing/callback
#   - https://YOUR-PRODUCTION-URL/api/auth/iracing/callback  (e.g. https://iracing-sr-optimizer.vercel.app/api/auth/iracing/callback)
IRACING_CLIENT_ID=
IRACING_CLIENT_SECRET=

# Optional: force a specific redirect URI (default: request origin + /api/auth/iracing/callback)
# IRACING_REDIRECT_URI=https://your-app.vercel.app/api/auth/iracing/callback
